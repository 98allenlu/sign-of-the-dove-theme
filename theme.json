{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "840px",
			"wideSize": "1200px"
		},
		"color": {
			"palette": [
				{
					"slug": "dove-white",
					"color": "#fbfbf9",
					"name": "Dove White"
				},
				{
					"slug": "charcoal",
					"color": "#1c1c1a",
					"name": "Charcoal"
				}
			]
		},
		"spacing": {
			"units": [ "rem", "px", "em" ],
			"blockGap": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--dove-white)",
			"text": "var(--wp--preset--color--charcoal)"
		}
	}
}